TZ=WAT
APP_URL=http://localhost:3333
FRONTEND_URL=http://localhost:3000
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=generate-with-node-ace-generate-key
NODE_ENV=development
SESSION_DRIVER=cookie
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=alaragest
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=BKNKV
RESEND_API_KEY=replace-with-your-own-resend-api-key

# Alertas operacionais (estoque crítico, produto perto da validade, venda cancelada de
# alto valor, reversão de estoque) — ver app/listeners/estoque_alertas.ts. Sem
# ALERT_EMAIL configurado, os alertas são calculados mas nenhum email é enviado.
ALERT_EMAIL=
ESTOQUE_LIMIAR_CRITICO=5
LOTE_VALIDADE_ALERTA_DIAS=30
VENDA_CANCELADA_LIMIAR=50000

# Drive
DRIVE_DISK=r2
R2_KEY=replace-with-your-own-r2-access-key-id
R2_SECRET=replace-with-your-own-r2-secret-access-key
R2_BUCKET=your-r2-bucket-name
R2_REGION=auto
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_DEV_SHOW_ENDPOINT=https://your-public-r2-dev-subdomain.r2.dev
