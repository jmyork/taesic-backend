<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ titulo }} — Alaragest</title>
    @include('emails/partials/alaragest_styles')
  </head>
  <body>
    <div class="wrapper">
      <div class="card">
        @include('emails/partials/alaragest_header')

        <div class="body">
          <p class="eyebrow">Alerta operacional</p>
          <h1>{{ titulo }}</h1>

          <div class="notice">
            @each(linha in linhas)
